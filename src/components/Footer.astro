---
// by Pawan Kumar Sharma
const startYear = 2025;
const currentYear = new Date().getFullYear();
const displayYear =
  startYear === currentYear
    ? currentYear
    : `${startYear}–${currentYear}`;
---

<footer class="mt-20 bg-[#0a0a0f] border-t border-white/5 text-gray-400">

  <div class="max-w-7xl mx-auto px-6 py-10">

    <div class="flex flex-col md:flex-row justify-between items-center gap-6">

      <!-- Left -->
      <div class="text-center md:text-left">
        <p class="text-sm">
          © {displayYear}
          <span class="text-white font-medium"> Pawan Kumar Sharma</span>.
          All rights reserved.
        </p>

        <p class="text-xs text-gray-500 mt-2">
          Full Stack MERN Developer & DevOps Enthusiast — Rourkela, Odisha, India
        </p>
      </div>

      <!-- Right -->
      <div class="flex gap-6 text-sm font-medium">

        <a
          href="https://github.com/itspksharma"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-indigo-400 transition duration-300"
        >
          GitHub
        </a>

        <a
          href="https://www.linkedin.com/in/itspksharma98/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-indigo-400 transition duration-300"
        >
          LinkedIn
        </a>

      </div>

    </div>

  </div>

</footer>