---
import promo from "../data/promotion.json";
---

{promo.enabled && (
  <div id="promoCard" class="promo-card">

    <button id="promoClose" class="promo-close">✕</button>

    <h3>{promo.title}</h3>
    <p>{promo.description}</p>

    <a href={promo.link} target="_blank">
      {promo.buttonText}
    </a>

  </div>
)}

<style>
.promo-card {
  position: fixed;
  top: 180px;
  right: 5%;
  width: 260px;
  padding: 18px;
  border-radius: 14px;

  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);

  color: white;
  z-index: 200;
  box-shadow: 0 10px 40px rgba(0,0,0,0.4);

  opacity: 0;
  transform: translateY(20px);
  transition: all 0.4s ease;
}

.promo-card.show {
  opacity: 1;
  transform: translateY(0);
}

.promo-card h3 {
  font-size: 15px;
  margin-bottom: 6px;
}

.promo-card p {
  font-size: 13px;
  color: #ccc;
  margin-bottom: 12px;
}

.promo-card a {
  display: inline-block;
  background: #6366f1;
  padding: 7px 14px;
  border-radius: 6px;
  font-size: 12px;
  text-decoration: none;
  color: white;
}

.promo-close {
  position: absolute;
  top: 6px;
  right: 8px;
  background: none;
  border: none;
  color: #ccc;
  font-size: 13px;
  cursor: pointer;
}

@media (max-width: 768px) {
  .promo-card {
    left: auto;
    right: auto;
    top: auto;
    bottom: 25px;

    transform: translateX(-50%);
    width: 90%;
    max-width: 320px;
  }
}
</style>

<script>
window.addEventListener("load", function () {

  const card = document.getElementById("promoCard");
  const closeBtn = document.getElementById("promoClose");

  if (!card) return;

  // show after 2 sec
  setTimeout(() => {
    card.classList.add("show");
  }, 2000);

  // close button
  closeBtn.addEventListener("click", function () {
    card.style.display = "none";
  });

});
</script>