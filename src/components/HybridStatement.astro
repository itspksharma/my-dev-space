---
import hybrid from "../data/hybrid.json";
---

<section class="bg-black/60 backdrop-blur-sm">

  <div class="max-w-4xl mx-auto text-center space-y-10">

    <p class="text-indigo-400 uppercase tracking-widest text-sm">
      {hybrid.label}
    </p>

    <h2 class="text-3xl sm:text-4xl font-bold leading-snug">
      {hybrid.title}
    </h2>

    <p class="text-gray-400 text-lg leading-relaxed">
      {hybrid.description}
    </p>

    <div class="w-24 h-1 bg-indigo-500 mx-auto rounded-full"></div>

  </div>

</section>