---
import techstack from "../data/techstack.json";
---

<section class="relative py-28 px-6 bg-black/60 backdrop-blur-sm">
    

  <div class="max-w-6xl mx-auto text-center mb-8">
    <h2 class="text-2xl font-semibold text-white">
      Tech Ecosystem
    </h2>
  </div>

  <!-- Marquee Wrapper -->
  <div class="relative w-full overflow-hidden">

    <div class="flex whitespace-nowrap animate-marquee gap-16 text-gray-400 text-lg font-medium">

      {techstack.map(tech => (
        <span class="hover:text-indigo-400 transition duration-300">
          {tech}
        </span>
      ))}

      <!-- Duplicate for seamless loop -->
      {techstack.map(tech => (
        <span class="hover:text-indigo-400 transition duration-300">
          {tech}
        </span>
      ))}

    </div>

  </div>

</section>

<style is:global>
@keyframes marquee {
  0% { transform: translateX(0%); }
  100% { transform: translateX(-50%); }
}

.animate-marquee {
  animation: marquee 25s linear infinite;
}
</style>