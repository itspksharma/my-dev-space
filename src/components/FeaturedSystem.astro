---
import featured from "../data/featured.json";
---

<section class="relative py-28 px-6 bg-[#0f0f14] text-white">

  <div class="max-w-6xl mx-auto">

    <h2 class="text-4xl font-bold text-center mb-20">
      Featured System Architecture
    </h2>

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Image -->
      <div class="relative group">
        <img 
          src={featured.image} 
          alt={featured.title}
          class="rounded-2xl border border-white/10 shadow-2xl 
                 group-hover:scale-[1.02] transition duration-500"
        />
        <div class="absolute inset-0 rounded-2xl bg-indigo-500/5 
                    opacity-0 group-hover:opacity-100 transition duration-500"></div>
      </div>

      <!-- Content -->
      <div class="space-y-6">

        <div>
          <h3 class="text-2xl font-semibold text-indigo-400">
            {featured.title}
          </h3>
          <p class="text-gray-400 mt-2">
            {featured.subtitle}
          </p>
        </div>

        <p class="text-gray-400">
          {featured.description}
        </p>

        <div class="space-y-4 text-sm text-gray-400">

          <div>
            <span class="text-white font-medium">Problem:</span>
            <p>{featured.problem}</p>
          </div>

          <div>
            <span class="text-white font-medium">Solution:</span>
            <p>{featured.solution}</p>
          </div>

          <div>
            <span class="text-white font-medium">Scalability:</span>
            <p>{featured.scalability}</p>
          </div>

        </div>

        <!-- Tech Stack -->
        <div class="flex flex-wrap gap-3 pt-4">
          {featured.tech.map(tech => (
            <span class="px-3 py-1 text-xs rounded-full bg-white/5 border border-white/10">
              {tech}
            </span>
          ))}
        </div>

        <!-- CTA -->
        <div class="pt-6">
          <a 
            href={featured.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-6 py-3 rounded-lg bg-indigo-600 
                   hover:bg-indigo-700 transition font-medium shadow-lg shadow-indigo-500/30"
          >
            View Architecture
          </a>
        </div>

      </div>

    </div>

  </div>

</section>