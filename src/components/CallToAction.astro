---
import cta from "../data/cta.json";
---

<section class="relative py-28 px-6 bg-gradient-to-b from-[#0f0f14] to-[#0a0a0f] text-white border-t border-white/5">

  <div class="max-w-5xl mx-auto text-center space-y-8">

    <p class="text-indigo-400 uppercase tracking-widest text-sm">
      {cta.label}
    </p>

    <h2 class="text-3xl sm:text-4xl font-bold">
      {cta.title}
    </h2>

    <p class="text-gray-400 max-w-2xl mx-auto text-lg">
      {cta.description}
    </p>

    <div class="flex justify-center gap-6 pt-6 flex-wrap">

      <a
        href={cta.primaryButton.link}
        class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-lg font-medium transition duration-300 shadow-lg hover:shadow-indigo-500/40"
      >
        {cta.primaryButton.text}
      </a>

      <a
        href={cta.secondaryButton.link}
        class="border border-white/20 hover:border-indigo-400 text-white px-8 py-3 rounded-lg font-medium transition duration-300"
      >
        {cta.secondaryButton.text}
      </a>

    </div>

  </div>

</section>