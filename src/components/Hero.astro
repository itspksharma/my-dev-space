<section class="relative min-h-screen flex flex-col justify-center items-center text-center px-6 overflow-hidden">

  <!-- Background Base -->
  <div class="absolute inset-0 -z-40 bg-[#0a0a0f]"></div>
  

  <!-- Subtle Radial Glow -->
  <div class="absolute inset-0 -z-30 bg-[radial-gradient(circle_at_50%_30%,rgba(59,130,246,0.15),transparent_60%)]"></div>

  <!-- Animated Gradient Blur -->
  <div class="absolute inset-0 -z-20 bg-gradient-to-tr from-indigo-500/10 via-purple-500/10 to-blue-500/10 animate-gradient blur-3xl"></div>

  <!-- Profile -->
  <img
    src="profile.jpg"
    alt="Pawan Kumar Sharma - Full Stack MERN Developer"
    class="w-36 h-36 sm:w-44 sm:h-44 rounded-full shadow-2xl border border-white/10 mb-8 hover:scale-105 transition duration-500"
    loading="lazy"
  />

  <!-- Heading -->
  <h1 class="text-3xl sm:text-4xl md:text-6xl font-extrabold text-white leading-tight">
    Building Scalable Digital Experiences
  </h1>

  <!-- Sub Heading -->
  <h2 class="mt-4 text-xl sm:text-2xl text-indigo-400 font-semibold">
    Hi, I'm Pawan Kumar Sharma
  </h2>

  <!-- Typewriter -->
  <p id="typewriter" class="mt-3 text-lg text-gray-400 h-[1.5em]"></p>

  <!-- Description -->
  <p class="mt-6 text-gray-400 max-w-2xl">
    Full Stack MERN Developer & DevOps Enthusiast based in Rourkela(Odisha), India.
    I specialize in React, Node.js, Docker, Linux & automation-driven systems.
  </p>

  <!-- CTA Buttons -->
  <div class="mt-8 flex flex-wrap justify-center gap-4">
    <a href="/projects"
       class="px-6 py-3 rounded-lg bg-indigo-600 text-white font-medium hover:bg-indigo-700 transition shadow-lg shadow-indigo-600/30">
      View Projects
    </a>

    <a href="/contact"
       class="px-6 py-3 rounded-lg border border-white/10 text-white hover:bg-white/5 transition">
      Contact Me
    </a>
  </div>

</section>

<style is:global>
  @keyframes gradientMove {
    0% { transform: translateY(-10%) rotate(0deg); }
    50% { transform: translateY(10%) rotate(180deg); }
    100% { transform: translateY(-10%) rotate(360deg); }
  }

  .animate-gradient {
    animation: gradientMove 18s linear infinite;
  }
</style>

<script>
  const roles = [
    "Full Stack MERN Developer",
    "DevOps Enthusiast",
    "Automation Builder",
    "Open Source Contributor"
  ];

  let roleIndex = 0;
  let charIndex = 0;
  let currentText = "";
  let isDeleting = false;
  const speed = 80;
  const pause = 1500;

  const el = document.getElementById("typewriter");

  function typeLoop() {
    const role = roles[roleIndex];

    if (isDeleting) {
      currentText = role.substring(0, charIndex--);
    } else {
      currentText = role.substring(0, charIndex++);
    }

    el.textContent = currentText;

    if (!isDeleting && charIndex === role.length) {
      setTimeout(() => isDeleting = true, pause);
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
    }

    setTimeout(typeLoop, isDeleting ? speed / 2 : speed);
  }

  typeLoop();
</script>