---
import BaseLayout from "../layouts/BaseLayout.astro";
import servicesData from "../data/services.json";
---

<BaseLayout
  type="website"
  title={`${servicesData.pageTitle} | Pawan Kumar Sharma | AskDevPK`}
  description={servicesData.pageDescription}
  url="https://askdevpk.me/services"
>

<section class="max-w-6xl mx-auto px-6 py-24 space-y-28">

  <!-- Heading -->
  <div class="text-center space-y-6">
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight
      bg-gradient-to-r from-white via-indigo-300 to-indigo-500
      bg-clip-text text-transparent">
      {servicesData.pageTitle}
    </h1>

    <p class="text-lg text-gray-400 max-w-3xl mx-auto leading-relaxed">
      {servicesData.pageDescription}
    </p>
  </div>

  
<!-- Services Grid -->
<div class="grid gap-10 md:grid-cols-2">

  {servicesData.services.map(service => (

    <div class="relative group p-10 rounded-3xl
      bg-[#0f172a]
      border border-white/5
      hover:border-indigo-500/40
      hover:-translate-y-2
      transition duration-500 overflow-hidden">

      <!-- Animated Accent Line -->
      <div class="absolute top-0 left-0 w-0 h-1 bg-indigo-500
        group-hover:w-full transition-all duration-500"></div>

      <!-- Glow Layer -->
      <div class="absolute inset-0 opacity-0 group-hover:opacity-100
        bg-gradient-to-br from-indigo-600/10 via-purple-600/10 to-transparent
        transition duration-500"></div>

      <div class="relative z-10">

        <!-- Icon -->
        <div class="mb-6 w-14 h-14 flex items-center justify-center
          rounded-2xl bg-indigo-600/10
          border border-indigo-500/30
          text-indigo-400
          shadow-[0_0_20px_rgba(99,102,241,0.25)]
          group-hover:scale-110
          transition duration-300">

          {service.icon === "code" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6"
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M16 18l6-6-6-6M8 6l-6 6 6 6" />
            </svg>
          )}

          {service.icon === "server" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6"
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <rect x="3" y="4" width="18" height="6" rx="2" />
              <rect x="3" y="14" width="18" height="6" rx="2" />
            </svg>
          )}

          {service.icon === "cloud" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6"
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-width="2"
                d="M3 15a4 4 0 014-4h1a5 5 0 019.9 1H18a3 3 0 010 6H7a4 4 0 01-4-4z" />
            </svg>
          )}

          {service.icon === "speed" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6"
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          )}

          {service.icon === "data" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6"
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-width="2"
                d="M4 6h16M4 12h8m-8 6h16" />
            </svg>
          )}

        </div>

        <!-- Title -->
        <h2 class="text-xl font-semibold text-white mb-4
          group-hover:text-indigo-300 transition">
          {service.title}
        </h2>

        <!-- Description -->
        <p class="text-gray-400 text-sm leading-relaxed">
          {service.description}
        </p>

      </div>

    </div>

  ))}
</div>

  <!-- Academic Project Support -->
  <section>

    <div class="relative rounded-3xl
      bg-gradient-to-r from-indigo-600/10 to-purple-600/10
      border border-indigo-500/20
      p-14 text-center overflow-hidden">

      <p class="text-xs uppercase tracking-widest text-indigo-400 mb-4">
        For Students & Learners
      </p>

      <h2 class="text-3xl font-bold text-white mb-6">
        {servicesData.academicSupport.title}
      </h2>

      <p class="text-gray-300 max-w-3xl mx-auto leading-relaxed mb-10">
        {servicesData.academicSupport.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center">

        <a href="/contact"
          class="px-8 py-3 rounded-xl
          bg-indigo-600 hover:bg-indigo-500
          text-white font-semibold
          transition duration-300 shadow-lg hover:shadow-indigo-500/40">
          {servicesData.academicSupport.primaryButton}
        </a>

        <a href="/projects"
          class="px-8 py-3 rounded-xl
          border border-white/20
          hover:border-indigo-500/40
          text-white font-semibold
          transition duration-300">
          {servicesData.academicSupport.secondaryButton}
        </a>

      </div>

    </div>

  </section>

  <!-- Workflow -->
  <section class="space-y-16">

    <h2 class="text-3xl font-bold text-center text-white">
      Workflow
    </h2>

    <div class="space-y-12 max-w-4xl mx-auto">

      {servicesData.workflow.map(step => (
        <div class="relative pl-12">

          <div class="absolute left-0 top-1 w-9 h-9 flex items-center justify-center
            rounded-full bg-indigo-600 text-white text-sm font-bold
            shadow-[0_0_15px_rgba(99,102,241,0.5)]">
            {step.step}
          </div>

          <h3 class="text-white font-semibold mb-2">
            {step.title}
          </h3>

          <p class="text-gray-400 text-sm leading-relaxed">
            {step.description}
          </p>

        </div>
      ))}

    </div>

  </section>

  <!-- CTA -->
  <div class="text-center pt-16 border-t border-white/5 space-y-6">

    <h2 class="text-3xl font-bold text-white">
      Ready to Build a Structured System?
    </h2>

    <p class="text-gray-400 text-lg">
      Let’s discuss your idea and turn it into a scalable, production-ready solution.
    </p>

    <a
      href="/contact"
      class="inline-block px-10 py-4 rounded-xl
      bg-indigo-600 hover:bg-indigo-500
      text-white font-semibold
      transition duration-300
      shadow-lg hover:shadow-indigo-500/40">
      Start a Conversation
    </a>

  </div>

</section>

</BaseLayout>