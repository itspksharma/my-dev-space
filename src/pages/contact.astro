---
// by Pawan Kumar Sharma
import BaseLayout from "../layouts/BaseLayout.astro";
import contact from "../data/contact.json";
---

<BaseLayout
  type="website"
  title="Contact | Pawan Kumar Sharma | AskDevPK"
  description="Get in touch with Pawan Kumar Sharma (AskDevPK) for freelance projects, MERN stack development, DevOps setup, or collaboration opportunities."
  url="https://askdevpk.me/contact"
>

<section class="max-w-7xl mx-auto px-6 py-24">

  <!-- Page Heading -->
  <div class="text-center mb-16 space-y-4">
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight
      bg-gradient-to-r from-white via-indigo-300 to-indigo-500
      bg-clip-text text-transparent">
      Contact
    </h1>

    <p class="text-gray-400 max-w-2xl mx-auto">
      Open to meaningful collaborations, freelance projects, and long-term technical partnerships.
    </p>
  </div>

  <!-- Card Container -->
  <div class="grid md:grid-cols-2 gap-14
      bg-gradient-to-br from-[#111827] to-[#0f172a]
      border border-white/5 rounded-3xl p-12 shadow-xl">

    <!-- LEFT SIDE -->
    <div class="space-y-8">

      <div class="flex items-center gap-6">
        <img 
          src="/contact.jpg" 
          alt="Pawan Kumar Sharma"
          class="w-32 h-32 rounded-full object-cover border-4 border-indigo-500 shadow-lg"
        />

        <div>
          <h2 class="text-2xl font-bold text-white">
            Let’s Build Something Impactful
          </h2>
          <p class="text-gray-400 text-sm mt-2">
            Full Stack MERN Developer & DevOps Enthusiast
          </p>
        </div>
      </div>

      <p class="text-gray-400 leading-relaxed">
        Whether you need a scalable web platform, backend architecture, DevOps deployment,
        or automation-driven systems — I focus on performance, clarity, and long-term maintainability.
      </p>

      <!-- Contact Info -->
      <div class="space-y-3 text-gray-400 text-sm">

        <p>
          <span class="text-white font-medium">Email:</span>{" "}
          <a 
            href={`mailto:${contact.email}`}
            class="text-indigo-400 hover:text-indigo-300 transition"
          >
            {contact.email}
          </a>
        </p>

        <p>
          <span class="text-white font-medium">Website:</span>{" "}
          <a
            href={contact.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-indigo-400 hover:text-indigo-300 transition"
          >
            {contact.website}
          </a>
        </p>

      </div>

      <!-- Social -->
      <div class="flex gap-6 pt-4 border-t border-white/5">

        {contact.socials.map(social => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 text-sm rounded-full border border-white/10
              text-gray-300 hover:border-indigo-500/40 hover:text-indigo-300
              transition duration-300"
          >
            {social.platform}
          </a>
        ))}

      </div>

    </div>

    <!-- RIGHT SIDE FORM -->
    <div>

      <form 
        action="https://formsubmit.co/contact@askdevpk.me"
        method="POST"
        class="space-y-6"
      >

        <div>
          <input
            type="text"
            name="name"
            placeholder="Your Name"
            required
            class="w-full bg-[#0a0a0f] border border-white/10 rounded-xl p-4 text-white
              focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/30
              transition"
          />
        </div>

        <div>
          <input
            type="email"
            name="email"
            placeholder="Your Email"
            required
            class="w-full bg-[#0a0a0f] border border-white/10 rounded-xl p-4 text-white
              focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/30
              transition"
          />
        </div>

        <div>
          <textarea
            name="message"
            rows="5"
            placeholder="Tell me about your project..."
            required
            class="w-full bg-[#0a0a0f] border border-white/10 rounded-xl p-4 text-white
              focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/30
              transition"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold
            py-4 rounded-xl transition duration-300
            shadow-lg hover:shadow-indigo-500/40"
        >
          Send Message
        </button>

      </form>

      <p class="text-xs text-gray-500 text-center mt-6">
        Your information stays secure — no spam, just genuine responses.
      </p>

    </div>

  </div>

</section>

</BaseLayout>