---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a,b)=> b.data.pubDate - a.data.pubDate);

// Featured post
const featured = posts.find(post => post.data.featured);

// tags
const tags = [...new Set(posts.flatMap(p => p.data.tags || []))];

const username = "itspksharma";
let devtoPosts = [];

try {
  const res = await fetch(`https://dev.to/api/articles?username=${username}`);
  if (res.ok) devtoPosts = await res.json();
} catch (e) {}
---

<BaseLayout
title="Blogs | AskDevPK"
description="Insights, tutorials, and personal developer journey."
url="https://askdevpk.me/blog"
>

<section class="max-w-6xl mx-auto px-6 py-24 space-y-20">

<!-- PAGE HEADING -->

<div class="text-center mb-16 space-y-4">

<h1 class="text-5xl md:text-6xl font-extrabold tracking-tight
bg-gradient-to-r from-white via-indigo-300 to-indigo-500
bg-clip-text text-transparent">

Blogs

</h1>

<p class="text-gray-400 max-w-xl mx-auto">

Insights, tutorials, tech experiments and development journey.

</p>

</div>

<!-- SEARCH -->

<div class="max-w-xl mx-auto">

<input
id="search"
type="text"
placeholder="Search articles..."
class="w-full bg-[#0f172a] border border-white/10 rounded-xl px-5 py-3 text-white focus:outline-none focus:border-indigo-500"
/>

</div>

<!-- TAG FILTER -->

<div class="flex flex-wrap gap-3 justify-center">

<button
class="tag-btn bg-indigo-600 text-white px-4 py-1 rounded-full text-sm"
data-tag="all"
>
All
</button>

{tags.map(tag => (

<button
class="tag-btn bg-white/5 text-gray-300 px-4 py-1 rounded-full text-sm hover:bg-indigo-600 hover:text-white transition"
data-tag={tag}
>
{tag}
</button>

))}

</div>

<!-- FEATURED -->

{featured && (

<div class="bg-[#0f172a] border border-indigo-500/30 rounded-2xl p-10">

<p class="text-indigo-400 text-sm mb-2">Featured Article</p>

<h2 class="text-3xl font-bold text-white mb-4">
<a href={`/blog/${featured.slug}`}>
{featured.data.title}
</a>
</h2>

<p class="text-gray-400">
{featured.data.description}
</p>

</div>

)}

<!-- LOCAL POSTS -->

<div>

<h2 class="text-2xl font-semibold text-indigo-400 mb-8">
Articles
</h2>

<div
id="posts"
class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
>

{posts.map(post => (

<a
href={`/blog/${post.slug}`}
class="post-card block bg-[#0f172a] border border-white/5 rounded-2xl overflow-hidden hover:border-indigo-500/40 transition"
data-tags={(post.data.tags || []).join(",")}
>

{post.data.image && (

<img
src={post.data.image}
class="w-full h-44 object-cover"
/>

)}

<div class="p-6">

<h3 class="text-lg font-semibold text-white">
{post.data.title}
</h3>

<p class="text-gray-400 text-sm mt-2">
{post.data.description}
</p>

</div>

</a>

))}

</div>

</div>

<!-- DEV.TO -->

{devtoPosts.length > 0 && (

<div>

<h2 class="text-2xl font-semibold text-green-400 mb-8">
Dev.to Articles
</h2>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

{devtoPosts.map(post => (

<a
href={post.url}
target="_blank"
class="block bg-[#0f172a] border border-white/5 rounded-2xl overflow-hidden hover:border-green-500/40 transition"
>

<img
src={post.cover_image || "/images/blogs/default.png"}
class="w-full h-44 object-cover"
/>

<div class="p-6">

<h3 class="text-lg font-semibold text-white">
{post.title}
</h3>

<p class="text-gray-400 text-sm mt-2">
{post.description}
</p>

</div>

</a>

))}

</div>

</div>

)}

</section>

<script>

const search = document.getElementById("search");
const posts = document.querySelectorAll(".post-card");
const tagBtns = document.querySelectorAll(".tag-btn");

let activeTag = "all";

function filterPosts() {

const query = search.value.toLowerCase();

posts.forEach(post => {

const title = post.innerText.toLowerCase();
const tags = post.dataset.tags;

const matchSearch = title.includes(query);
const matchTag = activeTag === "all" || tags.includes(activeTag);

post.style.display = matchSearch && matchTag ? "block" : "none";

});

}

search.addEventListener("input", filterPosts);

tagBtns.forEach(btn => {

btn.addEventListener("click", () => {

activeTag = btn.dataset.tag;

tagBtns.forEach(b=>b.classList.remove("bg-indigo-600","text-white"));

btn.classList.add("bg-indigo-600","text-white");

filterPosts();

});

});

</script>

</BaseLayout>