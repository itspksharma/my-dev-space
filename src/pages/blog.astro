---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import readingTime from "reading-time";

let localPosts = await getCollection("blog");

localPosts = localPosts
  .filter(post => !post.data.draft)
  .sort((a,b)=> b.data.pubDate - a.data.pubDate);

const username = "itspksharma";
let devtoPosts = [];

try {
  const res = await fetch(`https://dev.to/api/articles?username=${username}`);
  if (res.ok) devtoPosts = await res.json();
} catch (e) {}
---

<BaseLayout
  title="Blog | AskDevPK"
  description="Technical insights, development notes, and learning journey."
  url="https://askdevpk.me/blog"
>

<section class="max-w-6xl mx-auto px-6 py-24 space-y-24">

  <!-- Hero -->
<!-- Page Heading -->

<div class="text-center mb-16 space-y-4">

  <h1 class="text-5xl md:text-6xl font-extrabold leading-tight tracking-tight
    bg-gradient-to-r from-white via-indigo-300 to-indigo-500
    bg-clip-text text-transparent pb-2">
    Blogs
  </h1>

<p class="text-gray-400 max-w-2xl mx-auto">

Insights, experiences, tech tutorials, and personal growth journey.

</p>

</div>

  <!-- Local Articles -->
  {localPosts.length > 0 && (
    <div>

      <h2 class="text-2xl font-semibold text-indigo-400 mb-10">
        Articles
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        {localPosts.map(post => {

          const stats = readingTime(post.body);

          return (

          <a href={`/blog/${post.slug}`}
            class="group block bg-[#0f172a] border border-white/5 rounded-2xl overflow-hidden hover:border-indigo-500/40 hover:-translate-y-1 transition">

            {post.data.image && (
              <img
                src={post.data.image}
                class="w-full h-44 object-cover group-hover:scale-105 transition"
                loading="lazy"
              />
            )}

            <div class="p-6 space-y-3">

              {post.data.featured && (
                <span class="text-xs text-indigo-400 font-semibold">
                  FEATURED
                </span>
              )}

              <h3 class="text-lg font-semibold text-white">
                {post.data.title}
              </h3>

              <p class="text-gray-400 text-sm">
                {post.data.description}
              </p>

              <div class="text-xs text-gray-500 flex gap-3 flex-wrap">

                <span>
                  {post.data.pubDate.toLocaleDateString("en-US")}
                </span>

                <span>•</span>

                <span>{stats.text}</span>

              </div>

              {post.data.tags && (
                <div class="flex flex-wrap gap-2 pt-2">

                  {post.data.tags.map(tag => (
                    <span class="text-xs bg-white/5 px-2 py-1 rounded">
                      #{tag}
                    </span>
                  ))}

                </div>
              )}

            </div>

          </a>

          )

        })}

      </div>
    </div>
  )}

  <!-- Dev.to Articles -->
  {devtoPosts.length > 0 && (
    <div>

      <h2 class="text-2xl font-semibold text-green-400 mb-10">
        Dev.to Articles
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        {devtoPosts.map(post => (

          <a href={post.url}
            target="_blank"
            class="group block bg-[#0f172a] border border-white/5 rounded-2xl overflow-hidden hover:border-green-500/40 hover:-translate-y-1 transition">

            <img
              src={post.cover_image || "/images/blogs/default.png"}
              class="w-full h-44 object-cover group-hover:scale-105 transition"
              loading="lazy"
            />

            <div class="p-6 space-y-3">

              <span class="text-xs text-green-400 font-semibold">
                DEV.TO
              </span>

              <h3 class="text-lg font-semibold text-white">
                {post.title}
              </h3>

              <p class="text-gray-400 text-sm">
                {post.description}
              </p>

            </div>

          </a>

        ))}

      </div>
    </div>
  )}

</section>

</BaseLayout>