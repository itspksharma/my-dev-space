---
import BaseLayout from "../layouts/BaseLayout.astro";
import projects from "../data/projects.json";

const categories = ["All", ...new Set(projects.map(p => p.category))];
---

<BaseLayout
  title="Projects | AskDevPK"
  description="Structured full-stack and DevOps projects by Pawan Kumar Sharma."
  url="https://askdevpk.me/projects"
>

<section class="max-w-7xl mx-auto px-6 py-24 space-y-16">

  <!-- Heading -->
<div class="text-center mb-16 space-y-4">
  <h1 class="text-5xl md:text-6xl font-extrabold leading-tight tracking-tight
    bg-gradient-to-r from-white via-indigo-300 to-indigo-500
    bg-clip-text text-transparent pb-2">
    Projects
  </h1>
</div>

  <!-- Filter Tabs -->
  <div class="flex flex-wrap justify-center gap-4">
    {categories.map(cat => (
      <button
        data-category={cat}
        class="filter-btn px-5 py-2 rounded-full border border-white/10 text-gray-300 hover:border-indigo-500/40 hover:text-indigo-300 transition">
        {cat}
      </button>
    ))}
  </div>

  <!-- Grid -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10 mt-10">

    {projects.map(project => (
      <div
        class="project-card group rounded-3xl bg-[#0f172a] border border-white/5 hover:border-indigo-500/40 hover:-translate-y-2 transition duration-500 overflow-hidden"
        data-category={project.category}
      >

        <a href={`/projects/${project.slug}`}>
          <img src={project.thumbnail}
            alt={project.title}
            class="w-full h-48 object-cover group-hover:scale-105 transition duration-500"
            loading="lazy" />
        </a>

        <div class="p-6 space-y-4">

          <div class="flex justify-between items-center">
            <span class="text-xs text-indigo-400 uppercase tracking-wide">
              {project.category}
            </span>

            {project.studentReady && (
              <span class="text-xs bg-green-600/20 border border-green-500/30 text-green-400 px-2 py-1 rounded-full">
                Student Friendly
              </span>
            )}
          </div>

          <h3 class="text-lg font-semibold text-white">
            {project.title}
          </h3>

          <p class="text-gray-400 text-sm leading-relaxed">
            {project.description}
          </p>

          <!-- Stack -->
          <div class="flex flex-wrap gap-2">
            {project.stack.map(tag => (
              <span class="px-2 py-1 text-xs rounded-full bg-white/5 text-gray-300 border border-white/10">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex gap-3 pt-4">
            <a href={`/projects/${project.slug}`} class="text-indigo-400 text-sm hover:text-indigo-300">
              View Case Study →
            </a>
          </div>

        </div>
      </div>
    ))}

  </div>

</section>

<script is:client>
  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll(".project-card");

  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;

      buttons.forEach(b => b.classList.remove("active-filter"));
      btn.classList.add("active-filter");

      cards.forEach(card => {
        if (category === "All" || card.dataset.category === category) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>

<style>
.active-filter {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  border-color: transparent;
}
</style>

</BaseLayout>