---
import BaseLayout from "../../layouts/BaseLayout.astro";
import projects from "../../data/projects.json";

export async function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.slug }
  }));
}

const { slug } = Astro.params;
const project = projects.find(p => p.slug === slug);
---

<BaseLayout
  title={`${project.title} | Case Study | AskDevPK`}
  description={project.description}
  url={`https://askdevpk.me/projects/${slug}`}
>

<section class="max-w-4xl mx-auto px-6 py-24 space-y-12">

  <h1 class="text-4xl font-bold text-white">
    {project.title}
  </h1>

  <img src={project.thumbnail}
    alt={project.title}
    class="rounded-2xl shadow-xl"
    loading="lazy" />

  <div class="space-y-6">

    <div>
      <h2 class="text-xl font-semibold text-indigo-400 mb-2">Problem</h2>
      <p class="text-gray-400">{project.problem}</p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-indigo-400 mb-2">Architecture</h2>
      <p class="text-gray-400">{project.architecture}</p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-indigo-400 mb-2">Impact</h2>
      <p class="text-gray-400">{project.impact}</p>
    </div>

    <div class="flex gap-4 pt-6">
      {project.sourceLink && (
        <a href={project.sourceLink}
          target="_blank"
          class="px-6 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white">
          Source Code
        </a>
      )}
      {project.demoLink && (
        <a href={project.demoLink}
          target="_blank"
          class="px-6 py-2 rounded-xl border border-white/20 text-white hover:border-indigo-500/40">
          Live Demo
        </a>
      )}
    </div>

  </div>

</section>

</BaseLayout>